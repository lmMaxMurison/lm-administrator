{
  "manifest_version": 3,
  "name": "LMDA Administrator",
  "version": "0.2.0",
  "description": "LogicMonitor admin tools to extend portal UI.",
  "permissions": ["tabs", "scripting", "sidePanel", "storage"],
  "host_permissions": ["https://*.logicmonitor.com/*"],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_title": "LMDA Administrator"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.logicmonitor.com/*"],
      "js": ["content/lm-content.js", "content/overlay-content.js"],
      "css": ["ui/overlay.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}